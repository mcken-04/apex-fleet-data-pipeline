table vehicles_clean
	lineageTag: 7dec12e5-7672-46ba-b5cd-41df080edd1a

	measure 'Vehicles Needing Attention' = ```
			
			    CALCULATE(
			        COUNTROWS('vehicles_clean'),
			        'vehicles_clean'[maintenance_status] IN {"Overdue", "Missing Log"})
			```
